{
  "name": "hoverfly-ts-decorators",
  "version": "0.1.0",
  "description": "TypeScript helpers for loading Hoverfly simulations in Mocha tests",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "license": "MIT",
  "author": "wilson",
  "keywords": ["hoverfly", "mocha", "testing", "simulation", "service-virtualization"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "mocha",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "axios": "^1.7.0"
  },
  "peerDependencies": {
    "mocha": "^10.0.0 || ^11.0.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.0.0",
    "@types/sinon": "^17.0.0",
    "mocha": "^11.0.0",
    "nock": "^13.0.0",
    "sinon": "^17.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
