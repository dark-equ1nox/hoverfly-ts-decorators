{
  "name": "hoverfly-ts-decorators",
  "version": "0.2.0",
  "description": "TypeScript helpers for loading Hoverfly simulations in Mocha tests",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "author": "wilson",
  "repository": {
    "type": "git",
    "url": "https://github.com/dark-equ1nox/hoverfly-ts-decorators.git"
  },
  "keywords": [
    "hoverfly",
    "mocha",
    "testing",
    "simulation",
    "service-virtualization"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "mocha",
    "test:integration": "mocha --require ts-node/register --spec 'test/integration/**/*.test.ts' --timeout 30000",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "axios": "1.15.0"
  },
  "peerDependencies": {
    "mocha": "^11.0.0"
  },
  "devDependencies": {
    "@types/mocha": "10.0.0",
    "@types/node": "22.0.0",
    "@types/sinon": "21.0.0",
    "mocha": "11.0.0",
    "nock": "14.0.0",
    "sinon": "21.0.0",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.5",
    "follow-redirects": ">=1.16.0",
    "diff": ">=8.0.3"
  }
}
